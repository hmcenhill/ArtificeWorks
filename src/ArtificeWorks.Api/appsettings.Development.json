{
  // The compose stack's OTLP endpoint (9.1). `docker compose up -d` brings up grafana/otel-lgtm
  // and Grafana is then at http://localhost:3000 — see docs/observability.md. Nothing here is
  // required: with the container stopped both hosts start and run exactly as before.
  "Telemetry": {
    "OtlpEndpoint": "http://localhost:4317",
    "IncludeDbStatements": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
      "RabbitMQ.Client": "Warning"
    }
  }
}
