{
  // Matches the API's and the worker's development settings so one trace really does span all
  // three services — they must export to the same collector or the waterfall has a hole in it.
  "Telemetry": {
    "OtlpEndpoint": "http://localhost:4317",
    "IncludeDbStatements": true
  },
  "Simulation": {
    // Development is where the factory is meant to look alive: pacing on so stages have dwell
    // time, and generation on so a board is never empty. Both are still off in the shipped
    // appsettings.json, which is what the test suite and a fresh clone see.
    "PacingEnabled": true,
    "GenerationEnabled": true,
    "GenerationIntervalSeconds": 20,
    "MaxInFlight": 8
  }
}
