{
  "ConnectionStrings": {
    "ArtificeWorksDatabase": "Host=127.0.0.1;Port=5432;Database=artificeworks;Username=postgres;Password=postgres"
  },
  // No RabbitMqConfiguration and no Outbox section: this host publishes and schedules, it does not
  // consume, and it creates orders over HTTP rather than by putting events on the bus (10.1).
  "Simulation": {
    // The API's front door. The generator posts here — a direct database write would skip 8.4's
    // idempotency filter, the DTO validation and the outbox row that all three exist to guarantee.
    "ApiBaseAddress": "http://localhost:5000",

    // Hard, per-deployment switches, independent of the settings row: the row says whether the
    // factory SHOULD generate and sweep, these say whether this process is allowed to. A second
    // simulation host started by accident cannot double the demand.
    "GeneratorEnabled": true,
    "WorldSweepEnabled": true,

    // Defaults for the settings row, written on first run and never stomped afterwards. Everything
    // here is a demo dial: change it live at PUT /system/simulation instead of restarting.
    "PacingEnabled": false,
    "PaceSecondsScheduled": 5,
    "PaceSecondsMaterialsReserved": 13,
    "PaceSecondsProductionCompleted": 5,
    "PaceSecondsReworkRequired": 8,
    "PaceSecondsInspectionPassed": 3,
    "PaceSecondsShipmentScheduled": 2,
    "PaceJitter": 0.25,

    "GenerationEnabled": false,
    "GenerationIntervalSeconds": 20,
    "MaxInFlight": 12,

    "WorldSweepIntervalHours": 6,
    "RetireAfterHours": 24,

    "SettingsRefreshMs": 5000
  },
  "Pace": {
    "RungsMs": [ 1000, 2000, 3000, 5000, 8000, 13000, 21000, 34000 ]
  },
  "Production": {
    "MaxRebuildAttempts": 3
  },
  "Inspection": {
    "FailureRate": 0.0,
    "AutoInspect": true
  },
  "Shipping": {
    "RefusalRate": 0.0,
    "TransitDays": 3,
    "AutoBook": true
  },
  "Telemetry": {
    "OtlpEndpoint": "",
    "OtlpProtocol": "Grpc",
    "SamplingRatio": 1.0,
    "IncludeDbStatements": false,
    "SnapshotIntervalMs": 5000
  },
  // Its own port, so all three hosts can run side by side on one machine.
  "WorkerHealth": {
    "Prefix": "http://localhost:5082/"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      // 9.3's levelling pass — see the API's appsettings for the reasoning. All three hosts agree,
      // which is the whole point of settling it.
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  }
}
