{
  "ConnectionStrings": {
    "ArtificeWorksDatabase": "Host=127.0.0.1;Port=5432;Database=artificeworks;Username=postgres;Password=postgres"
  },
  "RabbitMqConfiguration": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "artifice.events"
  },
  "Outbox": {
    "PollIntervalMs": 1000,
    "BatchSize": 50,
    "SentRetentionHours": 72
  },
  "Retry": {
    "DelaysMs": [ 5000, 30000, 120000 ]
  },
  "Production": {
    "MaxRebuildAttempts": 3
  },
  "Inspection": {
    "FailureRate": 0.0,
    "AutoInspect": true
  },
  "Shipping": {
    "RefusalRate": 0.0,
    "TransitDays": 3,
    "AutoBook": true
  },
  "Simulation": {
    // 10.1's pacing. OFF is the shipped default, so a fresh clone and the test suite behave
    // exactly as Epic 9 left them. Turn it on and a stage's event rests on a delay rung before
    // delivery — see docs/observability.md and docs/messaging-topology.md.
    //
    // Durations are per STAGE, keyed by the event that pays for it, and they are QUANTIZED onto
    // the Pace ladder below: 5s and 6s may resolve to the same rung. GET /system/simulation
    // reports which rung each one landed on.
    "PacingEnabled": false,
    "PaceSecondsScheduled": 5,
    "PaceSecondsMaterialsReserved": 13,
    "PaceSecondsProductionCompleted": 5,
    "PaceSecondsReworkRequired": 8,
    "PaceSecondsInspectionPassed": 3,
    "PaceSecondsShipmentScheduled": 2,
    "PaceJitter": 0.25,

    // 10.3's order generation. Off by default, matching Inspection:FailureRate and
    // Shipping:RefusalRate, so the integration suite is not racing invented orders.
    "GenerationEnabled": false,
    "GenerationIntervalSeconds": 20,
    "MaxInFlight": 12,

    // 10.4's world sweep. Long interval, generous retirement: it should be almost invisible.
    "WorldSweepIntervalHours": 6,
    "RetireAfterHours": 24,

    // How often each host re-reads the settings row (10.2).
    "SettingsRefreshMs": 5000
  },
  "Pace": {
    // 10.1's rung ladder, Fibonacci-ish and log-spaced. One TTL'd queue per entry. Configuring
    // this REPLACES the shipped ladder — the array starts empty in code precisely so it does;
    // see PaceConfiguration for the 8.1 binder footgun this avoids.
    "RungsMs": [ 1000, 2000, 3000, 5000, 8000, 13000, 21000, 34000 ]
  },
  "Telemetry": {
    "OtlpEndpoint": "",
    "OtlpProtocol": "Grpc",
    "SamplingRatio": 1.0,
    "IncludeDbStatements": false,
    "SnapshotIntervalMs": 5000
  },
  "WorkerHealth": {
    "Prefix": "http://localhost:5081/"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      // 9.3's levelling pass — see the API's appsettings for the reasoning. Both hosts agree,
      // which is the whole point of settling it.
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
      "RabbitMQ.Client": "Warning"
    }
  }
}
